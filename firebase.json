{
  "functions": {
    "source": "cloud-functions",
    "codebase": "default",
    "region": "europe-west1",
    "disallowLegacyRuntimeConfig": true
  },
  "hosting": {
    "public": "gridbox-portal/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "service-account.json",
      "*.ps1"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      { "source": "/portal/box/_next/:path*",         "destination": "/_next/:path*", "type": 301 },
      { "source": "/portal/box-events/_next/:path*",  "destination": "/_next/:path*", "type": 301 },
      { "source": "/portal/box-picture/_next/:path*", "destination": "/_next/:path*", "type": 301 }
    ],
    "rewrites": [
      { "source": "/admin/box/**", "destination": "/admin/box/_.html" },
      { "source": "/portal/box/__next.portal.box.txt", "destination": "/portal/box/__next.portal.txt" },
      { "source": "/portal/box/__next.portal.box.__PAGE__.txt", "destination": "/portal/box/__next.portal/box/__PAGE__.txt" },
      { "source": "/portal/box-events/__next.portal.box-events.txt", "destination": "/portal/box-events/__next.portal.txt" },
      { "source": "/portal/box-events/__next.portal.box-events.__PAGE__.txt", "destination": "/portal/box-events/__next.portal/box-events/__PAGE__.txt" },
      { "source": "/portal/box-picture/__next.portal.box-picture.txt", "destination": "/portal/box-picture/__next.portal.txt" },
      { "source": "/portal/box-picture/__next.portal.box-picture.__PAGE__.txt", "destination": "/portal/box-picture/__next.portal/box-picture/__PAGE__.txt" },
      { "source": "/portal/box", "destination": "/portal/box.html" },
      { "source": "/portal/box-events", "destination": "/portal/box-events.html" },
      { "source": "/portal/box-picture", "destination": "/portal/box-picture.html" }
    ]
  }
}
