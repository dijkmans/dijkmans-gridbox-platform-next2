{
  "functions": {
    "source": "cloud-functions",
    "codebase": "default",
    "region": "europe-west1",
    "disallowLegacyRuntimeConfig": true
  },
  "hosting": {
    "public": "gridbox-portal/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "service-account.json",
      "*.ps1"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/portal/box",         "destination": "/portal/box.html" },
      { "source": "/portal/box/",        "destination": "/portal/box.html" },
      { "source": "/portal/box-events",  "destination": "/portal/box-events.html" },
      { "source": "/portal/box-events/", "destination": "/portal/box-events.html" },
      { "source": "/portal/box-picture", "destination": "/portal/box-picture.html" },
      { "source": "/portal/box-picture/","destination": "/portal/box-picture.html" }
    ]
  }
}
