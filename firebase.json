{
  "functions": {
    "source": "cloud-functions",
    "codebase": "default",
    "region": "europe-west1",
    "disallowLegacyRuntimeConfig": true
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**",
      "web/**",
      "docs/**",
      "cloud-functions/**",
      "service-account.json",
      "*.ps1"
    ]
  }
}
